		"@tailwindcss/vite": "^4.2.1",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.2.3",
		"@types/pg": "^8.16.0",
		"@types/uuid": "^11.0.0",
		"eslint": "^9.0.0",
		"eslint-plugin-svelte": "^2.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^8.0.0"
	},
	"dependencies": {
