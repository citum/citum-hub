# Citum Hub Environment Variables
# Copy this file to .env.local and fill in values for local development.
# In Railway, variables are managed via the web UI and auto-injected.

# ============================================================================
# SHARED VARIABLES (Both hub-api and hub-web)
# ============================================================================

# PostgreSQL connection string
# Local: postgres://user:password@localhost:5432/citum
# Railway: Auto-injected from Postgres plugin
DATABASE_URL=postgres://localhost:5432/citum

# Server listen port
# hub-api: 3002
# hub-web: 3000
PORT=3002

# Feature flag: demo mode (auth bypass for PR previews)
# Set to "true" for PR preview environments
# Set to "false" for production (real GitHub OAuth)
PUBLIC_DEMO_MODE=false

# ============================================================================
# HUB-API ONLY
# ============================================================================

# GitHub OAuth App credentials (create at https://github.com/settings/developers)
# Production only; PR previews use PUBLIC_DEMO_MODE=true instead
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# JWT signing secret for session tokens
# Generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_64_character_hex_string

# Frontend URL (for OAuth redirect)
# Local: http://localhost:3000
# Railway: Use service reference ${{hub-web.RAILWAY_PUBLIC_DOMAIN}}
FRONTEND_URL=http://localhost:3000

# Path to bundled citum-core runtime assets (styles, registry, etc.)
# Docker: /app
# Local development: project root directory with citum-core cloned
CITUM_CORE_PATH=.

# ============================================================================
# HUB-WEB ONLY
# ============================================================================

# Hub API base URL (for SvelteKit proxy)
# Local: http://localhost:3002
# Railway: Use service reference ${{hub-api.RAILWAY_PUBLIC_DOMAIN}}
BACKEND_URL=http://localhost:3002

# Internal Hub API base URL (preferred for Railway server-to-server proxying)
# Local: http://localhost:3002
# Railway: http://hub-api.railway.internal:3002
BACKEND_INTERNAL_URL=http://localhost:3002

# SvelteKit CSRF/cookie origin
# Local: http://localhost:3000
# Railway: Use service reference ${{RAILWAY_PUBLIC_DOMAIN}}
ORIGIN=http://localhost:3000

# Git commit hash for version display in footer
# Auto-injected in Railway via Dockerfile build-arg
PUBLIC_COMMIT_HASH=

# ============================================================================
# LOCAL DEVELOPMENT NOTES
# ============================================================================

# To run locally:
#
# 1. Start PostgreSQL:
#    docker compose up -d
#
# 2. Build WASM bridge (if changed):
#    cd server/crates/wasm-bridge && wasm-pack build --target nodejs
#
# 3. Start hub-api (port 3002):
#    cd client && bun run dev:api
#
# 4. In another terminal, start hub-web (port 3000):
#    cd client && bun run dev
#
# Environment variables above apply to `dev:api` and `dev` targets.
# For OAuth testing, use real credentials; for demo-only testing, set PUBLIC_DEMO_MODE=true.
